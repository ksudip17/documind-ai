# ─────────────────────────────────────────────────────────────────────────────
# DocuMind AI — Backend Environment Variables
#
# USAGE:
#   cp .env.example .env
#   Fill in all values. Never commit .env to Git.
#
# PRODUCTION:
#   Set these as secrets in your deployment platform:
#   - AWS EC2: AWS Secrets Manager or EC2 Parameter Store
#   - Vercel (frontend): Vercel Environment Variables
#   - GitHub Actions: GitHub Encrypted Secrets
#
# NOTE:
#   All values marked [REQUIRED] must be present for the server to start.
#   See src/config/env.ts for the startup validator.
# ─────────────────────────────────────────────────────────────────────────────


# ── Application ───────────────────────────────────────────────────────────────

# [REQUIRED] Node environment: development | production | test
NODE_ENV=development

# [REQUIRED] Port the Express server listens on
PORT=5001

# [REQUIRED] URL of the frontend (used for CORS whitelist and CSP)
# Production example: https://documind.vercel.app
FRONTEND_URL=http://localhost:3000


# ── Authentication ────────────────────────────────────────────────────────────

# [REQUIRED] Secret used to sign and verify JWTs.
# Generate with: openssl rand -hex 64
# Must be at least 32 chars. Use a cryptographically random value in production.
JWT_SECRET=

# [REQUIRED] JWT expiry duration (e.g., 7d, 24h, 1h)
JWT_EXPIRES_IN=7d


# ── Database (PostgreSQL via Supabase) ────────────────────────────────────────

# [REQUIRED] Full PostgreSQL connection string (Supabase → Settings → Database → URI)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DATABASE_URL=


# ── Redis (Upstash) ───────────────────────────────────────────────────────────

# [REQUIRED] Redis connection URL used by ioredis (BullMQ + rate limiting)
# Upstash: redis://default:[password]@[host].upstash.io:6379
# Use rediss:// for TLS (recommended in production)
REDIS_URL=

# Optional: Upstash REST API (if you use the Upstash REST client instead of ioredis)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ── Supabase Storage ──────────────────────────────────────────────────────────

# [REQUIRED] Your Supabase project URL (Settings → API)
SUPABASE_URL=

# [REQUIRED] Supabase anon (public) key — safe to use client-side
SUPABASE_ANON_KEY=

# [REQUIRED] Supabase service role key — SERVER-SIDE ONLY. Never expose publicly.
# Has full database access. Treat like a root password.
SUPABASE_SERVICE_KEY=

# [REQUIRED] Name of the Supabase Storage bucket for uploaded documents
SUPABASE_STORAGE_BUCKET=documents


# ── AI Services ───────────────────────────────────────────────────────────────

# [REQUIRED] Groq API key — used for Llama 3.3 70B (answers) and Llama 3.1 8B (scoring)
# Get from: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: HuggingFace API token — required if using private models or
# exceeding the free inference API rate limits
HUGGINGFACE_API_TOKEN=


# ── Frontend (Next.js — set these in Vercel environment variables) ─────────────

# [REQUIRED for frontend] Public URL of the backend API
# Development: http://localhost:5001
# Production:  https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:5001

# [REQUIRED for frontend] Public Supabase URL (same as SUPABASE_URL)
NEXT_PUBLIC_SUPABASE_URL=

# [REQUIRED for frontend] Supabase anon key (same as SUPABASE_ANON_KEY)
NEXT_PUBLIC_SUPABASE_ANON_KEY=